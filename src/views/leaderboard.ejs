<%- include('partials/header') %>

<section class="page-head">
  <h1>Classement général</h1>
  <p class="page-sub">Tous les joueurs, classés au nombre de points.</p>
</section>

<section class="card">
  <table class="ranking">
    <thead>
      <tr><th>#</th><th>Joueur</th><th>Pts</th><th class="hide-sm">Scores exacts</th><th class="hide-sm">Bons résultats</th><th class="hide-sm">Pronos</th></tr>
    </thead>
    <tbody>
      <% if (rows.length === 0) { %>
        <tr><td colspan="6" class="empty">Aucun joueur pour l'instant.</td></tr>
      <% } %>
      <% rows.forEach((r, i) => { %>
        <tr class="<%= r.id === currentUserId ? 'me' : '' %>">
          <td class="rank-cell">
            <% if (i === 0) { %><span class="medal">🥇</span><% } else if (i === 1) { %><span class="medal">🥈</span><% } else if (i === 2) { %><span class="medal">🥉</span><% } else { %><%= i + 1 %><% } %>
          </td>
          <td class="player"><%= r.username %><% if (r.id === currentUserId) { %> <span class="you">toi</span><% } %></td>
          <td class="pts gold"><%= r.total %></td>
          <td class="hide-sm"><%= r.exacts %></td>
          <td class="hide-sm"><%= r.bons %></td>
          <td class="hide-sm"><%= r.joues %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('partials/footer') %>
