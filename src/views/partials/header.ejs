<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · Pronos CDM 2026</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@700&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/styles.css" />
  <link rel="icon" href="../../../public/favicon.svg" />
  
</head>
<body>
  <header class="site-header">
    <a class="brand" href="/">
      <span class="brand-mark">⚽</span>
      <span class="brand-text">PRONOS<span class="brand-accent">CDM</span>26</span>
    </a>
    <% if (currentUser) { %>
      <nav class="nav">
        <a href="/" class="<%= path === '/' ? 'active' : '' %>">Tableau de bord</a>
        <a href="/matches" class="<%= path.startsWith('/matches') ? 'active' : '' %>">Matchs</a>
        <a href="/leaderboard" class="<%= path === '/leaderboard' ? 'active' : '' %>">Classement</a>
        <a href="/leagues" class="<%= path.startsWith('/leagues') ? 'active' : '' %>">Ligues</a>
        <% if (currentUser.is_admin) { %>
          <a href="/admin" class="<%= path.startsWith('/admin') ? 'active' : '' %>">Admin</a>
        <% } %>
      </nav>
      <form action="/logout" method="post" class="nav-logout">
        <span class="nav-user"><%= currentUser.username %></span>
        <button type="submit" class="btn-ghost">Déconnexion</button>
      </form>
    <% } %>
  </header>
  <main class="container">
